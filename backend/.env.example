# Copy to .env and fill in. .env is gitignored.

# TikHub API token — social search/collection. Without it the app uses MockProvider.
TIKHUB_TOKEN=your_tikhub_token_here

# Anthropic API key — AI reply drafts (model: claude-haiku-4-5).
# Without it, drafts stay rule-based/seed and /mentions/{id}/regenerate returns 503.
LLM_API_KEY=

# Optional override; defaults to the Anthropic Messages endpoint.
# LLM_API_URL=https://api.anthropic.com/v1/messages

# Optional: secret for signing auth tokens (defaults to a dev value).
# JWT_SECRET=change-me

# Optional: set to 1 to run the background auto-collect scheduler.
# ENABLE_SCHEDULER=0
